@{
    ViewData["Title"] = "What BTCPay Server are you configuring?";
    ViewData["CurrentStep"] = 1;
}
@model UpdateSettings<DeploymentSettings, DeploymentAdditionalData>;
<form class="container" method="post" asp-action="DeploymentDestination">
    <input type="hidden" asp-for="Json" value="@Model.Json"/>
    <div class="row mb-4">
        <h2 class="text-center w-100">@ViewData["Title"]</h2>
    </div>
    <div class="row mb-5">
        @if (Model.Additional.AvailableDeploymentTypes.Contains(DeploymentType.ThisMachine))
        {
            <div class="col-md-@(12 / Model.Additional.AvailableDeploymentTypes.Count)">
                <label class="card-input-element-label">
                    <input type="radio" asp-for="Settings.DeploymentType" value="@DeploymentType.ThisMachine" class="card-input-element d-none"/>
                    <div class="card shadow-sm w-100 h-100">
                        <div class="card-img-top" style="background-image: url(assets/machine.svg);"></div>
                        <div class="card-body">
                            <h3 class="card-title text-center">This machine</h3>
                            <p class="card-text text-center">
                                We'll configure BTCPay on the current machine
                            </p>
                        </div>
                    </div>
                </label>
            </div>
        }
        @if (Model.Additional.AvailableDeploymentTypes.Contains(DeploymentType.RemoteMachine))
        {
            <div class="col-md-@(12 / Model.Additional.AvailableDeploymentTypes.Count)">
                <label class="card-input-element-label">
                    <input type="radio" asp-for="Settings.DeploymentType" value="@DeploymentType.RemoteMachine" class="card-input-element d-none"/>
                    <div class="card shadow-sm w-100 h-100">
                        <div class="card-img-top" style="background-image: url(assets/remote.svg);"></div>
                        <div class="card-body">
                            <h3 class="card-title text-center">A remote machine</h3>
                            <p class="card-text">A remote machine that you can provide the SSH connectivity details to so that the configurator automagically sets it up for you</p>
                        </div>
                    </div>
                </label>
            </div>
        }
        @if (Model.Additional.AvailableDeploymentTypes.Contains(DeploymentType.Manual))
        {
            <div class="col-md-@(12 / Model.Additional.AvailableDeploymentTypes.Count)">
                <label class="card-input-element-label">
                    <input type="radio" asp-for="Settings.DeploymentType" value="@DeploymentType.Manual" class="card-input-element d-none"/>
                    <div class="card shadow-sm w-100 h-100 mt-4 mt-md-0">
                        <div class="card-img-top" style="background-image: url(assets/shell.png);"></div>
                        <div class="card-body">
                            <h3 class="card-title text-center">Manual</h3>
                            <p class="card-text">We'll generate a bash script and a cloud-init script. Run it on your server or paste into your VPS provider's user-data field.</p>
                        </div>
                    </div>
                </label>
            </div>
        }
        <span asp-validation-for="Settings.DeploymentType" class="text-danger w-100 text-center"></span>
    </div>
    <div class="row mb-5" style="display: none" id="remote-machine-form">
        <div class="col-md-6 col-sm-12 offset-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="alert alert-warning">Using this option on an instance of this application that is not under your control opens you up to a security risk. Please only use this option if you trust the owner of this deployed app.</div>
                    <h3 class="card-title text-center pt-2">Remote Machine SSH Details</h3>
                    <div class="form-group">
                        <label asp-for="Settings.Host"></label>
                        <input class="form-control" asp-for="Settings.Host">
                        <span asp-validation-for="Settings.Host" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Settings.Username"></label>
                        <input class="form-control" asp-for="Settings.Username">
                        <span asp-validation-for="Settings.Username" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>Authentication method</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" asp-for="Settings.AuthMethod" value="@SSHAuthMethod.Password" id="auth-password">
                            <label class="btn btn-outline-primary" for="auth-password">Password</label>
                            <input type="radio" class="btn-check" asp-for="Settings.AuthMethod" value="@SSHAuthMethod.SSHKey" id="auth-sshkey">
                            <label class="btn btn-outline-primary" for="auth-sshkey">SSH Key</label>
                        </div>
                    </div>
                    <div id="password-auth-fields">
                        <div class="form-group">
                            <label asp-for="Settings.Password">Password</label>
                            <input type="password" class="form-control" asp-for="Settings.Password" placeholder="Password" value="@Model.Settings.Password">
                            <span asp-validation-for="Settings.Password" class="text-danger"></span>
                        </div>
                    </div>
                    <div id="sshkey-auth-fields" style="display: none">
                        <div class="form-group">
                            <label asp-for="Settings.SSHPrivateKey">SSH Private Key</label>
                            <textarea class="form-control" asp-for="Settings.SSHPrivateKey" rows="6" placeholder="Paste your private key here (-----BEGIN OPENSSH PRIVATE KEY-----)"></textarea>
                            <small class="form-text text-muted">Paste the contents of your private SSH key file.</small>
                            <span asp-validation-for="Settings.SSHPrivateKey" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="Settings.RootPassword">Root password (if ssh user is not root)</label>
                        <input type="password" class="form-control" asp-for="Settings.RootPassword" placeholder="Root Password" value="@Model.Settings.RootPassword">
                        <span asp-validation-for="Settings.RootPassword" class="text-danger"></span>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" asp-for="Additional.LoadFromServer">
                        <label class="form-check-label" asp-for="Additional.LoadFromServer"></label>
                        <span asp-validation-for="Additional.LoadFromServer" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky-cta d-flex justify-content-center">
        <button type="submit" class="btn btn-primary btn-lg btn-continue">Continue</button>
    </div>
</form>

@section Scripts
{
    <script>
    $(document).ready(function() {
        toggleForm();
        toggleAuthMethod();
        $("label").on("click", function() {
            setTimeout(function() { toggleForm(); toggleAuthMethod(); }, 50);
        });
        $("input[name='Settings.AuthMethod']").on("change", toggleAuthMethod);
    });

    function toggleForm(){
         var selectedDeploymentType = $('input[name=Settings\\.DeploymentType]:checked').val();
         if(selectedDeploymentType === "@nameof(DeploymentType.RemoteMachine)"){
             $("#remote-machine-form").show();
         }else{
              $("#remote-machine-form").hide();
         }
    }

    function toggleAuthMethod(){
        var method = $("input[name='Settings.AuthMethod']:checked").val();
        if(method === "@nameof(SSHAuthMethod.SSHKey)"){
            $("#password-auth-fields").hide();
            $("#sshkey-auth-fields").show();
        } else {
            $("#password-auth-fields").show();
            $("#sshkey-auth-fields").hide();
        }
    }
    </script>
}
