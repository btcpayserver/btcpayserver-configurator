@model UpdateSettings<ConfiguratorSettings, BTCPayServerDockerConfigurator.Controllers.DeployAdditionalData>
@{
    ViewData["Title"] = "Deploying your BTCPay Server!";
    ViewData["CurrentStep"] = 7;
    var id = Context.Request.RouteValues["id"];
    var isManual = Model.Settings?.DeploymentSettings?.DeploymentType == DeploymentType.Manual;
}
<div class="container">
    @if (!Model.Additional.InProgress)
    {
        if (!isManual)
        {
            <div class="row mb-4">
                <div class="col-md-6 col-sm-12 offset-md-3">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h3 class="card-title">Response</h3>
                            @if (Model.Additional.ExitStatus == 0)
                            {
                                <iframe src="@Url.Action("GetOnionUrl")" frameborder="0" class="w-100" style="height: 50px" scrolling="no">
                                </iframe>
                                <div class="input-group form-group">
                                    <input class="form-control border-right-0" onclick="this.select();" type="text" style="font-size:0.75em;" value="https://@Model.Settings.DomainSettings.Domain" readonly="">
                                        <a href="https://@Model.Settings.DomainSettings.Domain" class="input-group-text text-decoration-none p-0 px-2">
                                            <span class="input-group-addon">&rarr;</span>
                                        </a>
                                </div>
                            }
                            <code class="d-block" style="max-height: 250px; overflow-y: scroll">
                                @Html.Raw(Model.Additional.Output?.Replace("\n", "<br/>"))<br/>
                                @Html.Raw(Model.Additional.Error?.Replace("\n", "<br/>"))
                            </code>
                        </div>
                        @if (Model.Additional.ExitStatus != 0)
                        {
                            <form class="card-footer" asp-action="Deploy">
                                <button type="submit" class="btn btn-primary">Retry</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
        <div class="row mb-4">
            <div class="col-md-8 col-sm-12 offset-md-2">
                <div class="card shadow-sm deploy-card">
                    @if (isManual && !string.IsNullOrEmpty(Model.Additional.CloudInitScript))
                    {
                        <div class="card-header p-0">
                            <ul class="nav nav-tabs card-header-tabs" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-bash" type="button" role="tab">Bash Script</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-cloudinit" type="button" role="tab">Cloud-Init</button>
                                </li>
                            </ul>
                        </div>
                        <div class="card-body tab-content">
                            <div class="tab-pane fade show active" id="tab-bash" role="tabpanel">
                                <p>SSH into your server and run these commands:</p>
                                <code class="d-block">@Model.Additional.Bash</code>
                            </div>
                            <div class="tab-pane fade" id="tab-cloudinit" role="tabpanel">
                                <p>Copy this into the <strong>User Data</strong> / <strong>Cloud-Init</strong> field when creating a new VPS instance (DigitalOcean, Vultr, Hetzner, etc.).</p>
                                <textarea class="form-control" rows="16" readonly onclick="this.select();" style="font-family: var(--btcpay-font-family-monospace); font-size: 0.8em;">@Model.Additional.CloudInitScript</textarea>
                                <small class="form-text text-muted mt-2 d-block">The server will configure itself on first boot. Choose Ubuntu 22.04+ as your OS.</small>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="card-body">
                            <h3 class="card-title">@(isManual ? "Bash Script" : "Executed commands")</h3>
                            @if (isManual) { <p>SSH into your server and run these commands:</p> }
                            <code class="d-block">@Model.Additional.Bash</code>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
@if (Model.Additional.InProgress)
{
    <div class="modal" tabindex="-1" role="dialog" id="deploying-modal" data-bs-keyboard="false" data-bs-backdrop="static">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Deploying BTCPay Server</h5>
                </div>
                <div class="modal-body">
                    <p>We're sending the commands to the server and executing. This could take a few minutes!</p>
                    <div class="progress">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100" style="width: 100%"></div>
                    </div>
                    <code class="d-block my-2" id="output" style="max-height: 50vh; overflow-y: scroll;">
                        @Html.Raw(Model.Additional.Output?.Replace("\n", "<br/>"))
                    </code>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts
{
    <script>
    $(document).ready(function(){
        $("form").on("submit", function(){ new bootstrap.Modal(document.getElementById('deploying-modal')).show();});
    });
    </script>
    @if (Model.Additional.InProgress)
    {
        <script>
        $(document).ready(function(){
            new bootstrap.Modal(document.getElementById('deploying-modal')).show();
            update();
        });

        function update(){
             $.ajax({url: window.location + "?json=true", success: function(result){
                 if(!result.additional.inProgress){
                    window.top.location.reload();
                 }else{
                     window.setTimeout(update, 3000);
                 }
                $("#output").html(result.additional.output.replace(/\n/g, '<br/>'));
                var el = document.getElementById("output");
                el.scrollIntoView(false);
              }});
        }
        </script>
    }
}
