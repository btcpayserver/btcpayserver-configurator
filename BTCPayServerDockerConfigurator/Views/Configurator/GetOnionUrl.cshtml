@model BTCPayServerDockerConfigurator.Models.SSHClientExtensions.SSHCommandResult
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
<link rel="stylesheet" href="~/css/btcpayserver-variables.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/btcpayserver-main.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
@{
    Layout = null;
}

@if (Model.ExitStatus == 0)
{
    <div class="input-group mb-3">
        <a href="@Model.Output" class="input-group-text">
            <img src="/assets/Onion_Color.svg" height="16">
        </a>
        <input class="form-control" onclick="this.select();" type="text" style="font-size:0.75em;" value="http://@Model.Output" readonly="">
        <a href="http://@Model.Output" class="input-group-text text-decoration-none p-0 px-2" target="_parent">
            <span>⮞</span>
        </a>
    </div>
}
else
{
    <span>Onion could not be loaded. Retrying in 3 seconds.</span>
    <script>window.setTimeout(window.location.reload.bind(window.location), 3000);
    </script>
}
